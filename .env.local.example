# Copy this file to .env.local and fill in the values below.

# Google OAuth credentials from Google Cloud Console
# (APIs & Services > Credentials > OAuth client ID > Web application)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Random signing secret for Auth.js sessions/cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Supabase project settings (Project Settings > API).
# AUTH_SUPABASE_SECRET must be the secret/service-role key (sb_secret_...),
# never the publishable/anon key - it bypasses Row Level Security and is
# used server-only.
AUTH_SUPABASE_ID=
AUTH_SUPABASE_SECRET=
SUPABASE_URL=

# Stripe API keys (Developers > API keys) and webhook signing secret
# (Developers > Webhooks > your endpoint > Signing secret).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the Premium (recurring) and Lifetime (one-time)
# tiers. Create with `node --env-file=.env.local scripts/create-stripe-prices.mjs`.
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_LIFETIME=

# Resend (resend.com) for transactional email - contact form notifications,
# welcome emails, and payment confirmations.
RESEND_API_KEY=
CONTACT_NOTIFICATION_EMAIL=
CONTACT_FROM_EMAIL=

# Public base URL used to build links inside emails (e.g. "Go to Mock Tests").
# Set to the real deployed domain in production.
SITE_URL=http://localhost:3000
