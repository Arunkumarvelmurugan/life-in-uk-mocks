# Copy this file to .env.local and fill in the values below.

# Google OAuth credentials from Google Cloud Console
# (APIs & Services > Credentials > OAuth client ID > Web application)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Random signing secret for Auth.js sessions/cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Supabase project settings (Project Settings > API).
# AUTH_SUPABASE_SECRET must be the secret/service-role key (sb_secret_...),
# never the publishable/anon key - it bypasses Row Level Security and is
# used server-only.
AUTH_SUPABASE_ID=
AUTH_SUPABASE_SECRET=
SUPABASE_URL=

# Stripe API keys (Developers > API keys) and webhook signing secret
# (Developers > Webhooks > your endpoint > Signing secret).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the Premium (recurring) and Lifetime (one-time)
# tiers. Create with `node --env-file=.env.local scripts/create-stripe-prices.mjs`.
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_LIFETIME=

# Discounted launch-offer Price IDs (see src/lib/pricing.ts for the 30-day
# window). Create with `node --env-file=.env.local scripts/create-launch-prices.mjs`.
STRIPE_PRICE_PREMIUM_LAUNCH=
STRIPE_PRICE_LIFETIME_LAUNCH=

# Resend (resend.com) for transactional email - contact form notifications,
# welcome emails, and payment confirmations.
RESEND_API_KEY=
CONTACT_NOTIFICATION_EMAIL=
# "From" address for the contact form's internal notification to us (not
# seen by users - replies go to the form submitter via reply-to).
CONTACT_FROM_EMAIL=
# "From" address for emails sent to users (welcome, payment confirmation,
# renewal reminder). Both addresses need the same lifeinukmocks.co.uk domain
# verified in Resend, not separate verification per address.
TRANSACTIONAL_FROM_EMAIL=noreply@lifeinukmocks.co.uk

# Public base URL used to build links inside emails (e.g. "Go to Mock Tests").
# Set to the real deployed domain in production.
SITE_URL=http://localhost:3000

# Random secret that authenticates Vercel Cron's calls to /api/cron/*.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set the same value in Vercel's project environment variables - Vercel Cron
# automatically sends it as an Authorization: Bearer header.
CRON_SECRET=

# Google Analytics 4 measurement ID (Admin > Data Streams > your stream).
# Public by design (NEXT_PUBLIC_ - ships in the client bundle), not a secret.
# Only loaded client-side after a visitor accepts the cookie consent banner -
# see src/components/analytics.tsx and src/components/cookie-consent.tsx.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
